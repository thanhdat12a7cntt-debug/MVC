@using BBookWeb.DataAcess
@model Category

<div class="card shadow border-0 mt-4">
    <div class="card-header bg-secondary bg-gradient m-lg-0 py-3">
        <div class="col-12 text-center">
            <h1 class="text-white">Create Category</h1>
        </div>
    </div>
    <div class="card-body">
        <form method="post">
            <div class="border p-3 mt-4">
                <br />
                @* <div asp-validation-summary="ModelOnly"></div> *@
                <br />
                <div class="mb-3">
                    <label asp-for="Name" class="p-0"></label>
                    <input asp-for="Name" type="text" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <br />
                <div class="mb-3">
                    <label asp-for="DisplayOrder" class="p-0"></label>
                    <input asp-for="DisplayOrder" type="text" class="form-control" />
                    <span asp-validation-for="DisplayOrder" class="text-danger"></span>
                </div>
                <div>
                    <div class="col-6">
                        <button type="submit" class="btn btn-primary" style="width:150px">Submit</button>
                    </div>
                    <div class="col-6">
                        <a asp-controller="Category" asp-action="Index" class="btn btn-secondary mt-3" style="width:150px">Back to List</a>
                    </div>
                </div>
            </div>

        </form>

    </div>
</div>


@section Scripts{
    <partial name="_ValidationScriptsPartial"/>
}